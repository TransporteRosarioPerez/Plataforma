NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# Requerido para cron de alertas (/api/cron/document-alerts) y script migrate:legacy
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Solo para scripts CLI (apply:migrations, reset:legacy-data) — Supabase → Settings → Database → URI
# SUPABASE_DATABASE_URL=postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres

# BD legada Neon (Prisma) — solo para script de migración
LEGACY_DATABASE_URL=postgresql://user:pass@host/db?sslmode=require

# DigitalOcean Spaces (PDFs de viajes + archivos de documentos de entidad)
DO_SPACES_ENDPOINT=https://nyc3.digitaloceanspaces.com
DO_SPACES_REGION=nyc3
DO_SPACES_BUCKET=your-bucket
DO_SPACES_ACCESS_KEY=your-access-key
DO_SPACES_SECRET_KEY=your-secret-key

# Cron de alertas preventivas (Bearer en /api/cron/document-alerts)
# Generá un string aleatorio largo: openssl rand -hex 32
CRON_SECRET=your-random-secret

# WhatsApp — proveedor: twilio (default) o meta
# Para pruebas: Twilio WhatsApp Sandbox (gratis con límites)
WHATSAPP_PROVIDER=twilio

# Twilio WhatsApp
TWILIO_ACCOUNT_SID=your-account-sid
TWILIO_AUTH_TOKEN=your-auth-token
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# Meta WhatsApp Cloud API (si WHATSAPP_PROVIDER=meta)
# WHATSAPP_ACCESS_TOKEN=your-token
# WHATSAPP_PHONE_NUMBER_ID=your-phone-number-id
