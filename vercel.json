{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "installCommand": "pnpm install",
  "buildCommand": "pnpm build",
  "crons": [
    {
      "path": "/api/cron/document-alerts",
      "schedule": "0 11 * * *"
    },
    {
      "path": "/api/cron/purge-audit-logs",
      "schedule": "0 4 * * *"
    }
  ]
}
